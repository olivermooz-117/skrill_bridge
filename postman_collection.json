{
  "info": {
    "name": "SkillBridge API",
    "description": "Complete API testing collection for SkillBridge"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"test123\",\n  \"role\": \"client\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"test123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Gigs",
      "item": [
        {
          "name": "Get All Gigs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/gigs"
          }
        },
        {
          "name": "Create Gig",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/gigs",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Web Development\",\n  \"description\": \"I will build a stunning website\",\n  \"price\": 500,\n  \"delivery_days\": 7,\n  \"tags\": [\"web\", \"development\", \"react\"]\n}"
            }
          }
        },
        {
          "name": "Get Gig by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/gigs/1"
          }
        },
        {
          "name": "Update Gig",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/gigs/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Gig\",\n  \"price\": 600\n}"
            }
          }
        },
        {
          "name": "Delete Gig",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/gigs/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/orders",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/orders",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gig_id\": 1,\n  \"requirements\": \"I need a responsive website\"\n}"
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/orders/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/1"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/users/1",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"bio\": \"This is my updated bio\"\n}"
            }
          }
        }
      ]
    }
  ]
}